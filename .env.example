# ─────────────────────────────────────────────────────────────────────────────
# FinRAG-Eval — Environment Configuration
# Copy this file to .env and fill in actual values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ─── LLM Providers ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Default models — keep cheap ones for bulk eval
LLM_BULK_MODEL=gpt-4o-mini
LLM_QUALITY_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ─── SEC EDGAR ──────────────────────────────────────────────────────────────
# REQUIRED: EDGAR enforces this. Format: "Team Name email@example.com"
EDGAR_USER_AGENT=FinRAG-Eval Team contact@example.com
EDGAR_RATE_LIMIT_PER_SECOND=8  # SEC allows 10; we stay polite

# ─── Storage ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=finrag
POSTGRES_USER=finrag
POSTGRES_PASSWORD=changeme

CHROMA_HOST=localhost
CHROMA_PORT=8000

# ─── Paths ──────────────────────────────────────────────────────────────────
DATA_DIR=./data
RAW_FILINGS_DIR=./data/raw
PROCESSED_DIR=./data/processed
INDEX_DIR=./data/indexes
EVAL_RUNS_DIR=./data/eval_runs

# ─── Cost Controls ──────────────────────────────────────────────────────────
# Weekly team budget cap (USD). Eval harness will warn at 80%, block at 100%.
WEEKLY_BUDGET_USD=75
ENABLE_RESPONSE_CACHE=true

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json  # or "console" for dev

# ─── SEC EDGAR Contact (required by SEC fair-access policy) ─────────────────
SEC_CONTACT_EMAIL=your.email@example.com
SEC_COMPANY_NAME=FinRAG-Eval Team